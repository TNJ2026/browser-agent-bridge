{
  "manifest_version": 3,
  "name": "Browser Agent Bridge",
  "version": "1.0.0",
  "description": "Expose Chrome browser-control tools to a local agent through Native Messaging.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "debugger",
    "declarativeNetRequest",
    "nativeMessaging",
    "notifications",
    "scripting",
    "sidePanel",
    "storage",
    "webNavigation"
  ],
  "optional_permissions": [
    "downloads",
    "tabGroups",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Browser Agent Bridge"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/dom-a11y.js",
        "content/accessibility-tree.js",
        "content/visual-indicator.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "toggle-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the browser agent side panel"
    }
  },
  "key": ""
}
